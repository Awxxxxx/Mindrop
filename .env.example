# Volcengine Ark Agent Plan. Keep secrets in .env.local or Vercel env vars.
ARK_API_KEY=
ARK_ENDPOINT=https://ark.cn-beijing.volces.com/api/plan/v3
ARK_MODEL=deepseek-v4-pro

# Optional. Usually inferred from ARK_ENDPOINT:
# - openai for https://ark.cn-beijing.volces.com/api/plan/v3
# - anthropic for https://ark.cn-beijing.volces.com/api/plan
ARK_PROTOCOL=openai

# Vercel Cron + APNs remote reminder push.
CRON_SECRET=
SUPABASE_URL=https://ayzmmchrepbtfnjegqxp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY=
APNS_BUNDLE_ID=app.mindrop.ios
# Use sandbox for Debug/dev builds. Use production for TestFlight/App Store.
# The APNs key must include the same environment, or APNs returns BadEnvironmentKeyInToken.
APNS_ENVIRONMENT=production
# Optional. Set to 1 briefly while debugging APNs delivery, then turn it off.
REMOTE_PUSH_DEBUG=0

# Feishu/Lark user-owned custom bots.
# Users provide their own enterprise custom app credentials in the app. Mindrop encrypts them per connection.
# Recommended: generate with `openssl rand -base64 32`.
FEISHU_CREDENTIALS_KEY=
MINDROP_PUBLIC_URL=https://www.mindrop.chat

# App Store review entry. Leave empty before the App Store listing is ready.
# Example: https://apps.apple.com/app/id1234567890?action=write-review
MINDROP_APP_REVIEW_URL=
