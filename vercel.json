{
  "redirects": [
    {
      "source": "/app",
      "destination": "https://apps.apple.com/cn/app/%E5%BF%B5%E8%90%BD%E7%AC%94%E8%AE%B0/id6772984960",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/website/index.html"
    },
    {
      "source": "/privacy",
      "destination": "/website/privacy.html"
    },
    {
      "source": "/privacy.html",
      "destination": "/website/privacy.html"
    },
    {
      "source": "/styles.css",
      "destination": "/website/styles.css"
    },
    {
      "source": "/main.js",
      "destination": "/website/main.js"
    },
    {
      "source": "/favicon.ico",
      "destination": "/website/favicon.ico"
    },
    {
      "source": "/assets/:path*",
      "destination": "/website/assets/:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/send-reminders",
      "schedule": "* * * * *"
    }
  ]
}
