                        <subviews>
                            <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFit" horizontalHuggingPriority="251" verticalHuggingPriority="251" image="LaunchBrandIcon.png" translatesAutoresizingMaskIntoConstraints="NO" id="launch-logo">
